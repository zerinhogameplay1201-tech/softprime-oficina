<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Vendas</h2>
  <div>
    <a href="/sales/new" class="btn btn-primary btn-sm">Registrar venda</a>
  </div>
</div>

<table class="table table-striped">
  <thead>
    <tr><th>ID</th><th>Cliente</th><th>Itens</th><th>Total</th><th>Data</th><th></th></tr>
  </thead>
  <tbody>
    <% (sales || []).forEach(s => { %>
      <tr>
        <td><%= s._id %></td>
        <td><%= s.customer_name || '-' %></td>
        <td><%= (s.items || []).length %></td>
        <td>R$ <%= (s.total||0).toFixed(2) %></td>
        <td><%= s.created_at ? new Date(s.created_at).toLocaleString() : '-' %></td>
        <td><a class="btn btn-sm btn-outline-secondary" href="/sales/<%= s._id %>">Abrir</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('partials/footer') %>