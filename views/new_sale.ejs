<%- include('partials/header') %>

<h2>Registrar Venda</h2>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<form method="post" action="/sales">
  <input type="hidden" name="appointment_id" value="<%= appointment_id || '' %>"/>
  <div class="mb-3">
    <label class="form-label">Cliente (opcional)</label>
    <input name="customer_name" class="form-control" placeholder="Nome do cliente"/>
  </div>

  <div id="items-area">
    <div class="row g-2 align-items-end item-line mb-2">
      <div class="col-md-6">
        <label class="form-label">Peça</label>
        <select name="part_id" class="form-select" required>
          <option value="">-- selecione --</option>
          <% (parts || []).forEach(p => { %>
            <option value="<%= p._id %>"><%= p.name %> (Qtd: <%= p.quantity || 0 %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Quantidade</label>
        <input name="qty" type="number" class="form-control" value="1" min="1" required/>
      </div>
      <div class="col-md-3">
        <label class="form-label">Preço unit. (R$)</label>
        <input name="unit_price" type="number" step="0.01" class="form-control" value="0.00" required/>
      </div>
      <div class="col-md-1">
        <button type="button" class="btn btn-outline-danger btn-remove-line" title="Remover" style="display:none">−</button>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <button id="add-line" type="button" class="btn btn-sm btn-outline-secondary">Adicionar item</button>
  </div>

  <div class="mb-3">
    <label class="form-label">Observações</label>
    <textarea name="notes" class="form-control"></textarea>
  </div>

  <div class="d-flex gap-2">
    <button class="btn btn-primary">Registrar venda</button>
    <a class="btn btn-link" href="/sales">Cancelar</a>
  </div>
</form>

<script>
  // small client-side helper to add multiple item lines (converts names to arrays)
  document.getElementById('add-line').addEventListener('click', () => {
    const area = document.getElementById('items-area');
    const tpl = document.querySelector('.item-line');
    const clone = tpl.cloneNode(true);
    clone.querySelectorAll('input, select').forEach(el => {
      // clear values for new line
      if (el.tagName === 'SELECT') el.selectedIndex = 0;
      else el.value = el.name === 'qty' ? '1' : (el.name === 'unit_price' ? '0.00' : '');
    });
    clone.querySelector('.btn-remove-line').style.display = 'inline-block';
    area.appendChild(clone);
    updateNames();
  });

  document.body.addEventListener('click', (e) => {
    if (e.target.classList.contains('btn-remove-line')) {
      e.target.closest('.item-line').remove();
      updateNames();
    }
  });

  function updateNames() {
    document.querySelectorAll('.item-line').forEach((line, idx) => {
      line.querySelectorAll('select, input').forEach(el => {
        const base = el.name;
        el.name = base.endsWith('[]') ? base : base + '[]';
      });
    });
  }

  // initialize names properly
  updateNames();
</script>

<%- include('partials/footer') %>