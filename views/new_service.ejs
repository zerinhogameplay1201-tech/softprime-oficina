<%- include('partials/header') %>

<h2>Novo Serviço</h2>
<form method="post" action="/services">
  <div class="mb-3">
    <label class="form-label">Descrição</label>
    <input name="description" required class="form-control"/>
  </div>
  <div class="mb-3">
    <label class="form-label">Preço (R$)</label>
    <input name="price" type="number" step="0.01" class="form-control"/>
  </div>
  <div class="mb-3">
    <label class="form-label">Duração estimada (horas)</label>
    <input name="duration" type="number" step="0.1" class="form-control"/>
  </div>
  <div class="mb-3">
    <label class="form-label">Custo com peças (R$)</label>
    <input name="parts_cost" type="number" step="0.01" class="form-control"/>
  </div>
  <button class="btn btn-primary">Criar</button>
  <a class="btn btn-link" href="/services">Cancelar</a>
</form>

<%- include('partials/footer') %>