<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2>Agendamento <small class="text-muted">#<%= appt._id %></small></h2>
    <div class="small-muted">Detalhes do serviço e peças usadas</div>
  </div>
  <div>
    <a href="/appointments/<%= appt._id %>/estimate" class="btn btn-outline-primary btn-sm" target="_blank">PDF</a>
    <a href="/sales/new?appointment_id=<%= appt._id %>" class="btn btn-primary btn-sm">Adicionar peças</a>
    <a href="/appointments/<%= appt._id %>/edit" class="btn btn-outline-secondary btn-sm">Editar</a>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-7">
    <div class="card p-3 mb-3">
      <h5>Informações</h5>
      <p class="mb-1"><strong>Cliente:</strong> <%= customer ? customer.name : '-' %></p>
      <p class="mb-1"><strong>Veículo:</strong> <%= vehicle ? (vehicle.make + ' ' + vehicle.model + ' (' + (vehicle.plate||'-') + ')') : '-' %></p>
      <p class="mb-1"><strong>Serviço:</strong> <%= service ? service.description : '-' %></p>
      <p class="mb-1"><strong>Data agendada:</strong> <%= appt.scheduled_at ? new Date(appt.scheduled_at).toLocaleString() : '-' %></p>
      <p class="mb-1"><strong>Técnico:</strong> <%= appt.technician || '-' %></p>
      <p class="mb-0"><strong>Observações:</strong> <%= appt.notes || '-' %></p>
    </div>

    <div class="card p-3">
      <h5>Peças / Vendas vinculadas</h5>
      <% if ((sales || []).length === 0) { %>
        <div class="small-muted">Nenhuma peça registrada para este serviço.</div>
      <% } else { %>
        <% sales.forEach(s => { %>
          <div class="mb-3 p-2" style="border:1px solid #eef2f5; border-radius:8px;">
            <div class="d-flex justify-content-between">
              <div><strong>Venda #<%= s._id %></strong> — <small class="text-muted"><%= s.created_at ? new Date(s.created_at).toLocaleString() : '' %></small></div>
              <div>R$ <%= (s.total||0).toFixed(2) %></div>
            </div>
            <div class="mt-2">
              <ul class="mb-0">
                <% s.items.forEach(it => { %>
                  <li><strong><%= it.part_name %></strong> — Qtd: <%= it.qty %> — R$ <%= (it.unit_price||0).toFixed(2) %></li>
                <% }) %>
              </ul>
            </div>
            <div class="mt-2">
              <a class="btn btn-sm btn-outline-secondary" href="/sales/<%= s._id %>">Abrir venda</a>
            </div>
          </div>
        <% }) %>
        <div class="mt-2 text-end"><strong>Total peças:</strong> R$ <%= (partsTotal||0).toFixed(2) %></div>
      <% } %>
    </div>
  </div>

  <div class="col-md-5">
    <div class="card p-3">
      <h5>Resumo financeiro</h5>
      <p class="mb-1"><strong>Preço do serviço:</strong> R$ <%= service ? (service.price||0).toFixed(2) : '0.00' %></p>
      <p class="mb-1"><strong>Peças utilizadas:</strong> R$ <%= (partsTotal||0).toFixed(2) %></p>
      <hr/>
      <p class="h5"><strong>Total estimado:</strong> R$ <%= (computedTotal||0).toFixed(2) %></p>
    </div>
  </div>
</div>

<a class="btn btn-link" href="/appointments">Voltar</a>

<%- include('partials/footer') %>