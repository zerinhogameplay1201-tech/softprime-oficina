<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Peças / Estoque</h2>
  <div>
    <form class="d-flex" method="get" action="/parts">
      <input name="q" class="form-control form-control-sm me-2" placeholder="Pesquisar..." value="<%= q || '' %>"/>
      <button class="btn btn-sm btn-outline-secondary">Buscar</button>
    </form>
  </div>
</div>

<div class="mb-3">
  <a href="/parts/new" class="btn btn-primary btn-sm">Nova Peça</a>
</div>

<table class="table table-striped">
  <thead>
    <tr><th>Nome</th><th>SKU</th><th>Qtd</th><th>Preço venda</th><th>Estoque mínimo</th><th></th></tr>
  </thead>
  <tbody>
    <% (parts || []).forEach(p => { %>
      <tr class="<%= (p.quantity || 0) <= (p.min_stock || 0) ? 'table-warning' : '' %>">
        <td><%= p.name %></td>
        <td><%= p.sku || '-' %></td>
        <td><%= p.quantity || 0 %></td>
        <td>R$ <%= (p.sell_price||0).toFixed(2) %></td>
        <td><%= p.min_stock || 0 %></td>
        <td>
          <a class="btn btn-sm btn-outline-secondary" href="/parts/<%= p._id %>/edit">Editar</a>
          <form action="/parts/<%= p._id %>/delete" method="post" style="display:inline" onsubmit="return confirm('Excluir peça?')">
            <button class="btn btn-sm btn-outline-danger">Excluir</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('partials/footer') %>