<%- include('partials/header') %>

<div class="d-flex justify-content-between mb-3">
  <h2>Clientes</h2>
  <a class="btn btn-success" href="/customers/new">Novo cliente</a>
</div>

<form class="mb-3 row" method="get" action="/customers">
  <div class="col-auto">
    <input name="q" value="<%= q || '' %>" class="form-control" placeholder="Pesquisar clientes..."/>
  </div>
  <div class="col-auto">
    <button class="btn btn-secondary">Buscar</button>
  </div>
</form>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Nome</th>
      <th>Telefone</th>
      <th>Email</th>
      <th>Criado</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% (customers || []).forEach(c => { %>
      <tr>
        <td><a href="/customers/<%= c._id || c.id %>"><%= c.name %></a></td>
        <td><%= c.phone %></td>
        <td><%= c.email %></td>
        <td><%= c.created_at ? new Date(c.created_at).toLocaleString() : '-' %></td>
        <td>
          <a class="btn btn-sm btn-outline-primary" href="/customers/<%= c._id || c.id %>">Abrir</a>
          <a class="btn btn-sm btn-outline-secondary" href="/customers/<%= c._id || c.id %>/edit">Editar</a>
          <form action="/customers/<%= c._id || c.id %>/delete" method="post" style="display:inline" onsubmit="return confirm('Excluir cliente? Esta ação não pode ser desfeita.')">
            <button class="btn btn-sm btn-outline-danger" type="submit">Excluir</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('partials/footer') %>