<% layout('layout') -%>
<div class="d-flex justify-content-between mb-3">
  <h2>Clientes</h2>
  <a class="btn btn-success" href="/customers/new">Novo cliente</a>
</div>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Nome</th>
      <th>Telefone</th>
      <th>Email</th>
      <th>Criado</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% customers.forEach(c => { %>
      <tr>
        <td><a href="/customers/<%= c.id %>"><%= c.name %></a></td>
        <td><%= c.phone %></td>
        <td><%= c.email %></td>
        <td><%= new Date(c.created_at).toLocaleString() %></td>
        <td><a class="btn btn-sm btn-outline-primary" href="/customers/<%= c.id %>">Abrir</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>