<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Softpime Oficina</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <a class="navbar-brand" href="/">Softpime Oficina</a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><a class="nav-link" href="/customers">Clientes</a></li>
            <li class="nav-item"><a class="nav-link" href="/vehicles">Veículos</a></li>
            <li class="nav-item"><a class="nav-link" href="/services">Serviços</a></li>
            <li class="nav-item"><a class="nav-link" href="/appointments">Agendamentos</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container">
      <% if (typeof flash !== 'undefined') { %>
        <div class="alert alert-info"><%= flash %></div>
      <% } %>
      <%- body %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>