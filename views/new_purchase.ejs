<%- include('partials/header') %>

<h2>Registrar Compra</h2>

<% if (typeof errors !== 'undefined' && errors && errors.length) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  </div>
<% } %>

<form method="post" action="/purchases">
  <div class="mb-3">
    <label class="form-label">Fornecedor</label>
    <input name="supplier" class="form-control" placeholder="Nome do fornecedor" />
  </div>

  <div class="mb-3">
    <label class="form-label">Peça</label>
    <select name="part_id" class="form-select" required>
      <option value="">-- selecione --</option>
      <% (parts || []).forEach(p => { %>
        <option value="<%= p._id %>"><%= p.name %> (SKU: <%= p.sku || '-' %>) — Qtd atual: <%= p.quantity || 0 %></option>
      <% }) %>
    </select>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <label class="form-label">Quantidade</label>
      <input name="quantity" type="number" class="form-control" value="1" min="1" required/>
    </div>
    <div class="col-md-4 mb-3">
      <label class="form-label">Preço unitário (R$)</label>
      <input name="unit_price" type="number" step="0.01" class="form-control" value="0.00" required/>
    </div>
    <div class="col-md-4 mb-3">
      <label class="form-label">Data</label>
      <input name="purchased_at" type="date" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>" />
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label">Observações</label>
    <textarea name="notes" class="form-control"></textarea>
  </div>

  <div class="d-flex gap-2">
    <button class="btn btn-primary">Registrar compra</button>
    <a class="btn btn-link" href="/parts">Cancelar</a>
  </div>
</form>

<%- include('partials/footer') %>