<% layout('layout') -%>
<div class="d-flex justify-content-between mb-3">
  <h2>Serviços</h2>
  <a class="btn btn-success" href="/services/new">Novo serviço</a>
</div>

<table class="table table-striped">
  <thead>
    <tr><th>Descrição</th><th>Preço</th><th>Criado</th></tr>
  </thead>
  <tbody>
    <% (services || []).forEach(s => { %>
      <tr>
        <td><%= s.description %></td>
        <td>R$ <%= (s.price||0).toFixed(2) %></td>
        <td><%= s.created_at ? new Date(s.created_at).toLocaleString() : '-' %></td>
      </tr>
    <% }) %>
  </tbody>
</table>