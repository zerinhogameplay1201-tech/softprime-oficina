<%- include('partials/header') %>

<h2>Editar Serviço</h2>
<form method="post" action="/services/<%= service._id %>/update">
  <div class="mb-3">
    <label class="form-label">Descrição</label>
    <input name="description" class="form-control" value="<%= service.description %>"/>
  </div>
  <div class="mb-3">
    <label class="form-label">Preço (R$)</label>
    <input name="price" type="number" step="0.01" class="form-control" value="<%= service.price %>"/>
  </div>
  <button class="btn btn-primary">Salvar</button>
  <a class="btn btn-link" href="/services">Cancelar</a>
</form>

<%- include('partials/footer') %>